# Frontend (Vite)
# Set this to your backend URL when deploying to production
VITE_API_URL=http://localhost:4000/api

# Backend (Node.js/Express)
# Port the Express server runs on
PORT=4000

# CORS - Frontend URL (needed for production deployment)
CLIENT_ORIGIN=http://localhost:5173

# Admin password (for login)
ADMIN_PASSWORD=your_password_here

# Email configuration (for contact form)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
CONTACT_EMAIL_TO=recipient@example.com
