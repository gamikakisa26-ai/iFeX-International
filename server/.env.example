# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# SMTP configuration — used by Nodemailer to send contact form submissions.
# Example values shown for a Gmail SMTP relay; swap for your provider
# (SendGrid, Amazon SES, Mailgun, Postmark, corporate SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-app-password

# Where contact form submissions should be delivered
CONTACT_RECEIVER_EMAIL=hello@ifexinternational.com

# The "from" address used when sending. Some providers require this to
# match the authenticated SMTP_USER domain.
CONTACT_SENDER_EMAIL=no-reply@ifexinternational.com

# Admin panel — the password used to log in at /admin/login.
# Change this to something strong before deploying anywhere public.
ADMIN_PASSWORD=5HM88fq2q97@+
